{
  "name": "edgeconnect",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "build:star-wasm": "node scripts/build-star-wasm.mjs",
    "bench:scoring": "node scripts/benchmark-star-scoring.mjs",
    "start": "next start",
    "lint": "eslint src scripts e2e playwright.config.ts vitest.config.ts vitest.setup.ts stryker.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:run": "playwright test",
    "check": "npm run typecheck && npm run lint && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "onnxruntime-web": "^1.27.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "qs": "^6.15.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  }
}
